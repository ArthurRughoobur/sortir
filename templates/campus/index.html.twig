{% extends 'base.html.twig' %}

{% block title %}Campus{% endblock %}

{% block body %}
    <h1>Les Campus</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for campus in campuses %}
            <tr>
                <td>{{ campus.id }}</td>
                <td>{{ campus.name }}</td>
                <td>    {% if is_granted("ROLE_ADMIN") %}

                    <a href="{{ path('app_campus_show', {'id': campus.id}) }}">
                        <button>Détail</button></a>
                    <a href="{{ path('app_campus_edit', {'id': campus.id}) }}">
                        <button>Modifier</button></a>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">Pas de campus</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>


    <a href="{{ path('app_campus_new') }}">
    {% if is_granted("ROLE_ADMIN") %}
        <button>Créer un campus</button></a>
    {% endif %}
{% endblock %}
