{% extends 'base.html.twig' %}

{% block title %}Page introuvable{% endblock %}

{% block body %}
    <main class="error-page">
        <section class="error-container">
            <div class="error-card">
                <p class="error-code">404</p>
                <h1 class="error-title">Page introuvable</h1>
                <h2 class="error-subtitle">
                    La page que vous cherchez n’existe pas ou n’est plus disponible.
                </h2>

                <p class="error-text">
                    Vérifiez l’adresse saisie ou retournez à l’accueil pour continuer votre navigation.
                </p>

                <div class="error-actions">
                    <a href="{{ path('main_event') }}" class="btn btn-primary">Retour au site</a>
                </div>
            </div>
        </section>
    </main>
{% endblock %}
