{% extends 'base.html.twig' %}

{% block body %}
    <section class="user-detail-page">

        <div class="user-detail-card">

            <header class="user-detail-header">
                <h1 class="user-detail-username">{{ userById.username }}</h1>
                <span class="user-detail-status">
                {{ userById.student == 1 ? 'Ancien élève' : 'En formation' }}
            </span>
            </header>

            <div class="user-detail-grid">

                <div class="user-detail-item">
                    <span class="label">Prénom</span>
                    <span class="value">{{ userById.name }}</span>
                </div>

                <div class="user-detail-item">
                    <span class="label">Nom</span>
                    <span class="value">{{ userById.lastname }}</span>
                </div>

                <div class="user-detail-item">
                    <span class="label">Téléphone</span>
                    <span class="value">{{ userById.phone }}</span>
                </div>

                <div class="user-detail-item">
                    <span class="label">Email</span>
                    <span class="value">{{ userById.email }}</span>
                </div>

                <div class="user-detail-item">
                    <span class="label">Campus</span>
                    <span class="value">{{ userById.campus.name }}</span>
                </div>

            </div>

        </div>

    </section>
{% endblock %}
