{% extends 'base.html.twig' %}

{% block title %}City index{% endblock %}

{% block body %}
    <h1>City index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>ZipCode</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for city in cities %}
            <tr>
                <td>{{ city.id }}</td>
                <td>{{ city.name }}</td>
                <td>{{ city.zipCode }}</td>
                <td>
                    {% if is_granted("ROLE_ADMIN") %}
                    <a href="{{ path('app_city_show', {'id': city.id}) }}">
                        <button class="">Détail</button></a>
                    <a href="{{ path('app_city_edit', {'id': city.id}) }}">
                        <button>Modifier</button></a>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">Pas de donées</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    {% if is_granted("ROLE_ADMIN") %}
    <a href="{{ path('app_city_new') }}">
        <button>Créer une nouvelle ville</button></a>
    {% endif %}
{% endblock %}
