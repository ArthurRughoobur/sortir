{% extends 'base.html.twig' %}

{% block title %}Campus{% endblock %}

{% block body %}
    <h1>Campus</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ campus.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ campus.name }}</td>
            </tr>
        </tbody>
    </table>
    {% if is_granted("ROLE_ADMIN") %}

    <a href="{{ path('app_campus_index') }}">
        <button>Retour aux Campus</button></a>

    <a href="{{ path('app_campus_edit', {'id': campus.id}) }}">
        <button>Modifier</button></a>

    {{ include('campus/_delete_form.html.twig') }}
    {% endif %}
{% endblock %}
