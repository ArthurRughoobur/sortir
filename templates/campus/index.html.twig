{% extends 'base.html.twig' %}

{% block title %}Campus{% endblock %}

{% block body %}
    <section class="index-section">
    <h1 class="title-location">Les Campus</h1>

        <section class="filtreList location">
        {{ form_start(formCampusSearch) }}
        {{ form_row(formCampusSearch.name) }}
        {{ form_end(formCampusSearch) }}
    </section>

        <table class="tableLocation">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for campus in campusList %}
            <tr>
                <td>{{ campus.id }}</td>
                <td>{{ campus.name }}</td>
                <td>
                    {% if is_granted("ROLE_ADMIN") %}
                    <a href="{{ path('app_campus_edit', {'id': campus.id}) }}">
                        <button class="btn-update">Modifier</button></a>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">Pas de campus</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    {% if is_granted("ROLE_ADMIN") %}
        <a href="{{ path('app_campus_new') }}">
        <button class="retourMenu">Créer un campus</button></a>
    {% endif %}
    </section>
{% endblock %}
