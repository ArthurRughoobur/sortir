{% extends 'base.html.twig' %}

{% block title %}Accès refusé{% endblock %}

{% block body %}
    <main class="error-page">
        <section class="error-container">
            <div class="error-card">
                <p class="error-code">403</p>
                <h1 class="error-title">Accès refusé</h1>
                <h2 class="error-subtitle">
                    Vous n’avez pas l’autorisation d’accéder à cette page.
                </h2>

                <p class="error-text">
                    Il est possible que cette ressource soit réservée à certains utilisateurs
                    ou que vous ne disposiez pas des droits nécessaires.
                </p>

                <div class="error-actions">
                    <a href="{{ path('main_event') }}" class="btn btn-primary">Retour au site</a>
                </div>
            </div>
        </section>
    </main>
{% endblock %}
