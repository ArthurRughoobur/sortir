<div {{ attributes }}>
    {{ form_errors(form) }}

    {{ form_start(form, {
        attr: {
            'data-model': 'on(change)|*'
        }
    }) }}

    <div class="">
        {{ form_row(form.adress) }}
    </div>

    <div class="">
        <label>Rue :</label>
        <input type="text" value="{{ street }}" readonly class="form-control">
    </div>

    {% for field in form.children %}
        {% if field.vars.name not in ['adress', 'save', 'publish'] %}
            {{ form_row(field) }}
        {% endif %}
    {% endfor %}

    <div class="">
        <button
            type="submit"
            name="save"
            value="save"
            class="btn btn-secondary"
            data-action="live#action"
            data-live-action-param="save"
        >
            Sauvegarder
        </button>

        <button
            type="submit"
            name="publish"
            value="publish"
            class="btn btn-primary"
            data-action="live#action"
            data-live-action-param="publish"
        >
            Publier la sortie
        </button>

        <a href="{{ path('main_event') }}" class="btn btn-secondary">
            Annuler !
        </a>
    </div>

    {{ form_end(form) }}
</div>
