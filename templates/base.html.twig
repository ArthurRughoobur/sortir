</head>
<body>
<div class="container">
    <header class="header">
        {% include 'views/nav/nav.html.twig' %}
    </header>
    <main>
        {# read and display all flash messages #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash flash-{{ label }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}
        {% block body %}{% endblock %}
    </main>
    <footer>
        {% include 'views/nav/navFooter.html.twig' %}
        <div class="footer-infos">
            <p>
                &copy; {{ 'now'|date('Y') }} On s'fait ça! -- Projet réalisé en collaboration avec Arthur RUGHOOBUR et Adrien LE CLECH.
            </p>
        </div>
    </footer>
</div>
{% block extraJs %} {% endblock %}
</body>
</html>
