{% extends 'base.html.twig' %}

{% block title %}City{% endblock %}

{% block body %}
    <h1>City</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ city.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ city.name }}</td>
            </tr>
            <tr>
                <th>ZipCode</th>
                <td>{{ city.zipCode }}</td>
            </tr>
        </tbody>
    </table>
    {% if is_granted("ROLE_ADMIN") %}

    <a href="{{ path('app_city_index') }}">
        <button>Retour aux villes</button></a>

    <a href="{{ path('app_city_edit', {'id': city.id}) }}">
        <button>Modifier</button></a>

    {{ include('city/_delete_form.html.twig') }}
    {%  endif %}
{% endblock %}
