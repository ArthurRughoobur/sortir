{% extends 'base.html.twig' %}

{% block title %}Villes{% endblock %}

{% block body %}
    <section class="index-section">
        <h1 class="title-location">Les Villes</h1>

        <section class="filtreList location">
            {{ form_start(formCitySearch) }}
            {{ form_row(formCitySearch.name) }}
            {{ form_end(formCitySearch) }}
        </section>

        <table class="tableLocation">
            <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Code Postal</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for city in cityList %}
                <tr>
                    <td>{{ city.id }}</td>
                    <td>{{ city.name }}</td>
                    <td>{{ city.zipCode }}</td>
                    <td>
                        {% if is_granted("ROLE_ADMIN") %}
                            <a href="{{ path('app_city_edit', {'id': city.id}) }}">
                                <button class="btn-update">Modifier</button>
                            </a>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4">Pas de données</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        {% if is_granted("ROLE_ADMIN") %}
            <a href="{{ path('app_city_new') }}">
                <button class="retourMenu">Créer une nouvelle ville</button>
            </a>
        {% endif %}

    </section>
{% endblock %}
