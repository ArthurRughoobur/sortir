{% extends 'base.html.twig' %}

{% block title %}Mentions légales{% endblock %}

{% block body %}
    <div class="container my-5">
        <h1 class="mb-4">Mentions légales</h1>

        <h2>Éditeur du site</h2>
        <p>
            Le présent site est édité par <strong>[Nom de l’école]</strong><br>
            Statut : [statut]<br>
            Adresse : [adresse complète]<br>
            Téléphone : [numéro]<br>
            Email : [adresse email]
        </p>

        <h2>Responsable de la publication</h2>
        <p>[Nom et prénom / fonction]</p>

        <h2>Hébergement</h2>
