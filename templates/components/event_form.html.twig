<div {{ attributes }}>
    {# Affichage des flash messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}
    {{ form_errors(form) }}

    {{ form_start(form, {
        attr: {
            'data-model': 'on(change)|*',
            'data-action': 'live#action:prevent',

        }
    }) }}

    <div class="">
        {{ form_row(form.adress) }}
    </div>
    <div class="">
        <a href="{{ path('create_adress') }}">➕</a>
        <label>Ville :</label>
        <input type="text" value="{{ city }}" readonly class="form-control">
    </div>
    <div class="">
        <label>Rue :</label>
        <input type="text" value="{{ street }}" readonly class="form-control">
    </div>
    <div class="">
        <label>Latitude :</label>
        <input type="text" value="{{ latitude }}" readonly class="form-control">
    </div>
    <div class="">
        <label>Longitude :</label>
        <input type="text" value="{{ longitude }}" readonly class="form-control">
    </div>


    {% for field in form.children %}
        {% if field.vars.name not in ['adress', 'save', 'publish'] %}
            {{ form_row(field) }}
        {% endif %}
    {% endfor %}

    <div class="">
        <button
            type="submit"
            name="save"
            value="save"
            class="btn btn-secondary"
            data-action="live#action"
            data-live-action-param="save"
        >
            Sauvegarder
        </button>

        <button
            type="submit"
            name="publish"
            value="publish"
            class="btn btn-primary"
            data-action="live#action"
            data-live-action-param="publish"
        >
            Publier la sortie
        </button>

        <a href="{{ path('main_event') }}" class="btn btn-secondary">
            Annuler!
        </a>
    </div>

    {{ form_end(form) }}

</div>
