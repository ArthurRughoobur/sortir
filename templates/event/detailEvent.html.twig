{% extends 'base.html.twig' %}

{% block title %}Détail de la sortie{% endblock %}

{% block body %}
    <section class="event-page">
        <article class="event-card">

            <header class="event-header">
                <h1 class="event-title">{{ event.name }}</h1>
                <span class="event-status">{{ event.status.name }}</span>
            </header>

            <div class="event-grid">
                <div class="event-item">
                    <span class="label">Catégorie</span>
                    <span class="value">{{ event.category.name }}</span>
                </div>

                <div class="event-item">
                    <span class="label">Date et heure</span>
                    <span class="value">{{ event.dateStart|date("d/m/Y H:i") }}</span>
                </div>

                <div class="event-item">
                    <span class="label">Date limite d'inscription</span>
                    <span class="value">{{ event.deadline|date("d/m/Y") }}</span>
                </div>

                <div class="event-item">
                    <span class="label">Inscrits / Places</span>
                    <span class="value">{{ event.registred.count }}/{{ event.maxIscription }}</span>
                </div>

                <div class="event-item">
                    <span class="label">Organisateur</span>
                    <span class="value">{{ event.organizer.name }}</span>
                </div>

                <div class="event-item">
                    <span class="label">Campus</span>
                    <span class="value">{{ event.campus.name }}</span>
                </div>

                <div class="event-item">
                    <span class="label">Lieu</span>
                    <span class="value">{{ event.adress.city.name }}</span>
                </div>

                <div class="event-item">
                    <span class="label">Rue</span>
                    <span class="value">{{ event.adress.street }}</span>
                </div>

                <div class="event-item">
                    <span class="label">Code postal</span>
                    <span class="value">{{ event.adress.city.zipCode }}</span>
                </div>

                <div class="event-item">
                    <span class="label">Latitude</span>
                    <span class="value">{{ event.adress.latitude }}</span>
                </div>

                <div class="event-item">
                    <span class="label">Longitude</span>
                    <span class="value">{{ event.adress.longitude }}</span>
                </div>
            </div>

            <div class="event-description-block">
                <h2>Description</h2>
                <p>{{ event.eventInfo }}</p>
            </div>

            {% if event.canceledInfo %}
                <div class="event-cancel-block">
                    <h2>Détail annulation</h2>
                    <p>{{ event.canceledInfo }}</p>
                </div>
            {% endif %}

            <div class="participants-block">
                <h2>Participants</h2>
                <ul class="participants-list">
                    {% for user in event.registred %}
                        <li>
                            <a href="{{ path('user_detail_id', {'id': user.id}) }}">
                                {{ user.name }} {{ user.lastname }}
                            </a>
                        </li>
                    {% else %}
                        <li>Aucun participant</li>
                    {% endfor %}
                </ul>
            </div>

            <div class="event-actions">
                {% if app.user in event.registred %}
                    <form method="post" action="{{ path('desinscription_event', {id: event.id}) }}">
                        <button type="submit" class="btnEventDetail">Se désinscrire</button>
                    </form>
                {% elseif event.registred.count < event.maxIscription %}
                    <form method="post" action="{{ path('inscription_event', {id: event.id}) }}">
                        <button type="submit" class="btnEventDetail ">S'inscrire</button>
                    </form>
                {% endif %}

                {% if is_granted('EVENT_EDIT', event) %}
                    <a class="btnEventDetail" href="{{ path('update_event', {'id': event.id}) }}">
                        Modifier l'évènement
                    </a>
                {% endif %}
            </div>

        </article>
    </section>
{% endblock %}
